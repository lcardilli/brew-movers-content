# Ahrefs API token — get from https://ahrefs.com/api
AHREFS_TOKEN=your_ahrefs_api_token_here

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Blob token — added automatically when you link a Blob store via the Vercel dashboard
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
